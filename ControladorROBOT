#include <stdio.h>
#include <stdlib.h>
#include <math.h>

#include <webots/robot.h>
#include <webots/motor.h>
#include <webots/distance_sensor.h>
#include <webots/position_sensor.h>

// ==========================================
// CONFIGURACIONES BÁSICAS Y PARÁMETROS
// ==========================================
#define TIME_STEP 64
#define MAX_SPEED 6.28

#define LEFT 0
#define RIGHT 1

// Índices de los sensores del e-puck
#define PS_RIGHT_FRONT 0
#define PS_LEFT_FRONT 7
#define PS_LEFT_SIDE 6
#define PS_RIGHT_SIDE 1

// Dimensiones físicas del robot para odometría
#define WHEEL_RADIUS 0.0205 // Radio de la rueda (r)
#define AXLE_LENGTH 0.053 // Distancia entre ruedas (L)

// Parámetros de control local y filtrado
#define FRONT_THRESHOLD 400.0  
#define CLEAR_THRESHOLD 150.0  
#define FORWARD_SPEED 4.0
#define TURN_SPEED 2.5
#define ALPHA 0.85

// Parámetros del Filtro de Kalman
#define Q 1.0
#define R 15.0

// ==========================================
// ESTRUCTURAS PARA NAVEGACIÓN GLOBAL (PUNTOS)
// ==========================================
typedef struct {
  double x;
  double y;
} Position2D;

// UN SOLO INICIO Y UNA SOLA META LEJANA
Position2D punto_inicio = {0.0, 0.0};
Position2D punto_meta   = {1.2, 1.2}; 

int main(int argc, char **argv) {

  // Inicialización de Webots
  wb_robot_init();

  // Configuración de Actuadores
  WbDeviceTag motors[2];
  motors[LEFT] = wb_robot_get_device("left wheel motor");
  motors[RIGHT] = wb_robot_get_device("right wheel motor");

  wb_motor_set_position(motors[LEFT], INFINITY);
  wb_motor_set_position(motors[RIGHT], INFINITY);
  wb_motor_set_velocity(motors[LEFT], 0.0);
  wb_motor_set_velocity(motors[RIGHT], 0.0);

  // Configuración de Encoders de Rueda
  WbDeviceTag left_encoder = wb_robot_get_device("left wheel sensor");
  WbDeviceTag right_encoder = wb_robot_get_device("right wheel sensor");
  wb_position_sensor_enable(left_encoder, TIME_STEP);
  wb_position_sensor_enable(right_encoder, TIME_STEP);

  // Inicialización del arreglo de 8 Sensores de Distancia
  WbDeviceTag ps[8];
  char sensor_name[5];
  for (int i = 0; i < 8; i++) {
    sprintf(sensor_name, "ps%d", i);
    ps[i] = wb_robot_get_device(sensor_name);
    wb_distance_sensor_enable(ps[i], TIME_STEP);
  }

  // Variables heredadas del Laboratorio 2
  double prev_left_enc = 0.0;
  double prev_right_enc = 0.0;
  double filtered_front = 0.0;
  double estimated_distance = 0.0;
  double P = 1.0;

  // Variables de odometría plana
  double robot_x = punto_inicio.x;
  double robot_y = punto_inicio.y;
  double robot_phi = 0.0; 

  bool meta_alcanzada = false;
  bool evadiendo = false; 

  // Paso inicial para sincronizar encoders
  wb_robot_step(TIME_STEP);
  prev_left_enc = wb_position_sensor_get_value(left_encoder);
  prev_right_enc = wb_position_sensor_get_value(right_encoder);

  // Archivo log CSV para telemetría
  FILE *log_file = fopen("sensor_log.csv", "w");
  fprintf(log_file, "time,robot_x,robot_y,robot_phi,front_estimated,meta_alcanzada\n");

  printf("==================================================\n");
  printf("PROYECTO FINAL: MODO DIRECTO (INICIO -> META ÚNICA)\n");
  printf("==================================================\n");

  // ==========================================
  // BUCLE DE EJECUCIÓN PRINCIPAL
  // ==========================================
  while (wb_robot_step(TIME_STEP) != -1) {

    // 1. FILTRADO Y KALMAN
    double front_left = wb_distance_sensor_get_value(ps[PS_LEFT_FRONT]);
    double front_right = wb_distance_sensor_get_value(ps[PS_RIGHT_FRONT]);
    double left_side = wb_distance_sensor_get_value(ps[PS_LEFT_SIDE]);
    double right_side = wb_distance_sensor_get_value(ps[PS_RIGHT_SIDE]);

    double front_raw = fmax(front_left, front_right);
    filtered_front = ALPHA * filtered_front + (1.0 - ALPHA) * front_raw;

    double left_enc = wb_position_sensor_get_value(left_encoder);
    double right_enc = wb_position_sensor_get_value(right_encoder);

    double delta_left = left_enc - prev_left_enc;
    double delta_right = right_enc - prev_right_enc;

    prev_left_enc = left_enc;
    prev_right_enc = right_enc;

    double dist_left = WHEEL_RADIUS * delta_left;
    double dist_right = WHEEL_RADIUS * delta_right;
    double robot_advance = (dist_left + dist_right) / 2.0;

    double predicted_distance = estimated_distance + robot_advance * 100.0;
    double P_pred = P + Q;
    double K = P_pred / (P_pred + R);
    estimated_distance = predicted_distance + K * (filtered_front - predicted_distance);
    P = (1.0 - K) * P_pred;

    // 2. ACTUALIZACIÓN DE ODOMETRÍA COMPLETA
    double d_phi = (dist_right - dist_left) / AXLE_LENGTH;
    
    robot_x += robot_advance * cos(robot_phi + d_phi / 2.0);
    robot_y += robot_advance * sin(robot_phi + d_phi / 2.0);
    robot_phi += d_phi;

    robot_phi = atan2(sin(robot_phi), cos(robot_phi));

    // 3. CONDICIÓN DE PARADA EN META
    if (meta_alcanzada) {
      wb_motor_set_velocity(motors[LEFT], 0.0);
      wb_motor_set_velocity(motors[RIGHT], 0.0);
      
      static bool mensaje_impreso = false;
      if (!mensaje_impreso) {
        printf("\n>>> [¡META FINAL ALCANZADA!] Deteniendo motores por completo. <<<\n\n");
        mensaje_impreso = true;
      }
      continue; 
    }

    // Calcular distancia escalar a la meta única
    double distancia_a_meta = sqrt(pow(punto_meta.x - robot_x, 2) + pow(punto_meta.y - robot_y, 2));

    if (distancia_a_meta < 0.05) {
      meta_alcanzada = true;
      continue;
    }

    // 4. PLANIFICACIÓN LOCAL HÍBRIDA
    double angulo_a_meta = atan2(punto_meta.y - robot_y, punto_meta.x - robot_x);
    double error_angular = angulo_a_meta - robot_phi;
    error_angular = atan2(sin(error_angular), cos(error_angular)); 

    double left_speed = 0.0;
    double right_speed = 0.0;

    if (!evadiendo && estimated_distance > FRONT_THRESHOLD) {
      evadiendo = true;
    } else if (evadiendo && estimated_distance < CLEAR_THRESHOLD) {
      evadiendo = false;
    }

    if (evadiendo) {
      printf("[EVASIÓN] Pared detectada. Buscando salida lateral...\n");

      if (left_side > right_side) {
        left_speed = TURN_SPEED * 1.3;
        right_speed = -TURN_SPEED * 0.3;
      } else if (right_side > left_side) {
        left_speed = -TURN_SPEED * 0.3;
        right_speed = TURN_SPEED * 1.3;
      } else {
        if (error_angular > 0) {
          left_speed = -TURN_SPEED * 0.6;
          right_speed = TURN_SPEED * 1.2;
        } else {
          left_speed = TURN_SPEED * 1.2;
          right_speed = -TURN_SPEED * 0.6;
        }
      }
    } else {
      // CONTROL PROPORCIONAL DE RUMBO DIRECTO
      double Kp_angular = 5.0;
      double velocidad_base = 4.5;

      if (fabs(error_angular) > 0.5) {
        left_speed = -TURN_SPEED * (error_angular > 0 ? 1 : -1);
        right_speed = TURN_SPEED * (error_angular > 0 ? 1 : -1);
      } else {
        left_speed = velocidad_base - (Kp_angular * error_angular);
        right_speed = velocidad_base + (Kp_angular * error_angular);
      }
    }

    left_speed = fmax(fmin(left_speed, MAX_SPEED), -MAX_SPEED);
    right_speed = fmax(fmin(right_speed, MAX_SPEED), -MAX_SPEED);

    wb_motor_set_velocity(motors[LEFT], left_speed);
    wb_motor_set_velocity(motors[RIGHT], right_speed);

    double current_time = wb_robot_get_time();
    fprintf(log_file, "%f,%f,%f,%f,%f,%d\n",
            current_time, robot_x, robot_y, robot_phi, estimated_distance, meta_alcanzada);

    printf("Posición: X:%.2f Y:%.2f | Dist. Meta: %.2f m\n",
           robot_x, robot_y, distancia_a_meta);
  }

  fclose(log_file);
  wb_robot_cleanup();
  return 0;
}
